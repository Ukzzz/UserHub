<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <%- include('partials/head', { title: 'Register | UserHub' }) %>
</head>
<body class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 h-full flex flex-col transition-colors duration-300">
    <%- include('partials/navbar') %>

    <main class="flex-grow py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <!-- Hero Section -->
            <div class="text-center mb-12">
                <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-4">
                    Join Our <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-500">Community</span>
                </h1>
                <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
                    Create a professional profile and connect with others in our vibrant platform.
                </p>
            </div>

            <div class="max-w-2xl mx-auto">
                <div class="glass shadow-xl rounded-3xl p-8 md:p-12">
                    <h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
                        <i data-lucide="user-plus" class="text-indigo-600"></i>
                        Member Registration
                    </h2>

                    <form action="/read" method="POST" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Name -->
                            <div class="space-y-2">
                                <label for="name" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Full Name</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="user" class="w-5 h-5"></i>
                                    </div>
                                    <input type="text" id="name" name="name" class="form-input !pl-10" placeholder="John Doe" required />
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="space-y-2">
                                <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Email Address</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="mail" class="w-5 h-5"></i>
                                    </div>
                                    <input type="email" id="email" name="email" class="form-input !pl-10" placeholder="john@example.com" required />
                                </div>
                            </div>

                            <!-- Age -->
                            <div class="space-y-2">
                                <label for="age" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Age</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="calendar" class="w-5 h-5"></i>
                                    </div>
                                    <input type="number" id="age" name="age" class="form-input !pl-10" placeholder="25" min="18" required />
                                </div>
                            </div>

                            <!-- CNIC -->
                            <div class="space-y-2">
                                <label for="cnic" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Identification (CNIC)</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="id-card" class="w-5 h-5"></i>
                                    </div>
                                    <input type="text" id="cnic" name="cnic" class="form-input !pl-10" placeholder="1234567890123" required />
                                </div>
                            </div>
                        </div>

                        <!-- Location -->
                        <div class="space-y-2">
                            <label for="location" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Location</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                    <i data-lucide="map-pin" class="w-5 h-5"></i>
                                </div>
                                <input type="text" id="location" name="location" class="form-input !pl-10" placeholder="New York, USA" required />
                            </div>
                        </div>

                        <!-- Image URL -->
                        <div class="space-y-2">
                            <label for="image" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Profile Image URL</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                    <i data-lucide="image" class="w-5 h-5"></i>
                                </div>
                                <input type="url" id="image" name="image" class="form-input !pl-10" placeholder="https://unsplash.com/photo..." required />
                            </div>
                        </div>

                        <!-- Submit -->
                        <div class="pt-4">
                            <button type="submit" class="btn-primary w-full !text-lg !py-4 shadow-indigo-200 dark:shadow-none">
                                <i data-lucide="check-circle" class="w-6 h-6"></i>
                                Register Account
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>