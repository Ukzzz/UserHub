<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <%- include('partials/head', { title: 'Edit Profile | UserHub' }) %>
</head>
<body class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 h-full flex flex-col transition-colors duration-300">
    <%- include('partials/navbar') %>

    <main class="flex-grow py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <!-- Breadcrumbs / Back navigation -->
            <div class="mb-8">
                <a href="/read" class="inline-flex items-center gap-2 text-slate-500 hover:text-indigo-600 transition-colors">
                    <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    <span class="font-medium">Back to Database</span>
                </a>
            </div>

            <div class="max-w-2xl mx-auto">
                <div class="glass shadow-xl rounded-3xl p-8 md:p-12">
                    <div class="flex items-center gap-4 mb-10">
                        <div class="w-16 h-16 rounded-2xl overflow-hidden border-2 border-indigo-200 shadow-sm bg-white">
                            <img src="<%= user.image %>" alt="<%= user.name %>" class="w-full h-full object-cover" 
                                 onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>&background=random'" />
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold">Edit Profile</h2>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Update information for <%= user.name %></p>
                        </div>
                    </div>

                    <form action="/edit/<%= user._id %>?_method=PUT" method="POST" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Name -->
                            <div class="space-y-2">
                                <label for="name" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Full Name</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="user" class="w-5 h-5"></i>
                                    </div>
                                    <input type="text" id="name" name="name" value="<%= user.name %>" class="form-input !pl-10" required />
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="space-y-2">
                                <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Email Address</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="mail" class="w-5 h-5"></i>
                                    </div>
                                    <input type="email" id="email" name="email" value="<%= user.email %>" class="form-input !pl-10" required />
                                </div>
                            </div>

                            <!-- Age -->
                            <div class="space-y-2">
                                <label for="age" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Age</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="calendar" class="w-5 h-5"></i>
                                    </div>
                                    <input type="number" id="age" name="age" value="<%= user.age %>" class="form-input !pl-10" min="18" required />
                                </div>
                            </div>

                            <!-- CNIC -->
                            <div class="space-y-2">
                                <label for="cnic" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Identification (CNIC)</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                        <i data-lucide="id-card" class="w-5 h-5"></i>
                                    </div>
                                    <input type="text" id="cnic" name="cnic" value="<%= user.cnic %>" class="form-input !pl-10" required />
                                </div>
                            </div>
                        </div>

                        <!-- Location -->
                        <div class="space-y-2">
                            <label for="location" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Location</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                    <i data-lucide="map-pin" class="w-5 h-5"></i>
                                </div>
                                <input type="text" id="location" name="location" value="<%= user.location %>" class="form-input !pl-10" required />
                            </div>
                        </div>

                        <!-- Image URL -->
                        <div class="space-y-2">
                            <label for="image" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Profile Image URL</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                    <i data-lucide="image" class="w-5 h-5"></i>
                                </div>
                                <input type="url" id="image" name="image" value="<%= user.image %>" class="form-input !pl-10" required />
                            </div>
                        </div>

                        <!-- Submit -->
                        <div class="pt-6 flex flex-col sm:flex-row gap-4">
                            <button type="submit" class="btn-primary flex-1 !py-4 shadow-indigo-200 dark:shadow-none">
                                <i data-lucide="save" class="w-5 h-5"></i>
                                Update Profile
                            </button>
                            <a href="/read" class="btn-secondary px-8">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>