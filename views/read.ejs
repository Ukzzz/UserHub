<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <%- include('partials/head', { title: 'User Database | UserHub' }) %>
</head>
<body class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 h-full flex flex-col transition-colors duration-300">
    <%- include('partials/navbar') %>

    <main class="flex-grow py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <!-- Header section -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-12">
                <div>
                    <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white">User <span class="text-indigo-600">Database</span></h1>
                    <p class="text-slate-500 dark:text-slate-400 mt-1">Manage and view all registered community members.</p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="px-4 py-2 bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm">
                        <span class="text-sm font-semibold text-slate-500 dark:text-slate-400 mr-2">Total Users:</span>
                        <span class="text-lg font-bold text-indigo-600"><%= users.length %></span>
                    </div>
                </div>
            </div>

            <!-- Content grid -->
            <% if (users && users.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% users.forEach(function(user) { %>
                        <div class="glass rounded-3xl overflow-hidden hover-lift transition-all duration-300 shadow-lg group">
                            <!-- Card Header/Image -->
                            <div class="h-32 bg-gradient-to-r from-indigo-500 to-purple-500 relative">
                                <div class="absolute -bottom-10 left-6">
                                    <div class="w-20 h-20 rounded-2xl overflow-hidden border-4 border-white dark:border-slate-800 shadow-xl group-hover:scale-105 transition-transform duration-300">
                                        <img src="<%= user.image %>" alt="<%= user.name %>" class="w-full h-full object-cover bg-white" 
                                             onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(user.name) %>&background=random'" />
                                    </div>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div class="pt-14 pb-8 px-6">
                                <div class="mb-6">
                                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-1"><%= user.name %></h3>
                                    <div class="flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400">
                                        <i data-lucide="mail" class="w-3.5 h-3.5"></i>
                                        <%= user.email %>
                                    </div>
                                </div>

                                <div class="grid grid-cols-2 gap-4 mb-8">
                                    <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-2xl border border-slate-100 dark:border-slate-700">
                                        <p class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mb-1">Location</p>
                                        <div class="flex items-center gap-1 text-sm font-semibold truncate">
                                            <i data-lucide="map-pin" class="w-3 h-3 text-indigo-500"></i>
                                            <%= user.location %>
                                        </div>
                                    </div>
                                    <div class="bg-slate-50 dark:bg-slate-800/50 p-3 rounded-2xl border border-slate-100 dark:border-slate-700">
                                        <p class="text-[10px] uppercase tracking-wider font-bold text-slate-400 mb-1">Age</p>
                                        <div class="flex items-center gap-1 text-sm font-semibold">
                                            <i data-lucide="calendar" class="w-3 h-3 text-purple-500"></i>
                                            <%= user.age %> Years
                                        </div>
                                    </div>
                                </div>

                                <div class="flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-700">
                                    <div class="text-xs text-slate-400 italic">
                                        ID: <%= user.cnic %>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <a href="/edit/<%= user._id %>" class="p-2.5 bg-slate-100 dark:bg-slate-700 hover:bg-indigo-600 hover:text-white text-slate-600 dark:text-slate-300 rounded-xl transition-all duration-200" title="Edit User">
                                            <i data-lucide="edit-3" class="w-5 h-5"></i>
                                        </a>
                                        <form action="/read/<%= user._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to remove this user from the database? This action cannot be undone.')">
                                            <button type="submit" class="p-2.5 bg-slate-100 dark:bg-slate-700 hover:bg-rose-500 hover:text-white text-slate-600 dark:text-slate-300 rounded-xl transition-all duration-200" title="Delete User">
                                                <i data-lucide="trash-2" class="w-5 h-5"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-24 glass rounded-3xl border-dashed border-2 border-slate-200 dark:border-slate-700">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-100 dark:bg-slate-800 rounded-2xl text-slate-400 mb-4">
                        <i data-lucide="users" class="w-10 h-10"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">No users found</h2>
                    <p class="text-slate-500 dark:text-slate-400 mb-8">Start by registering a new member to your community.</p>
                    <a href="/" class="btn-primary inline-flex">
                        <i data-lucide="user-plus" class="w-5 h-5"></i>
                        Register New User
                    </a>
                </div>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>